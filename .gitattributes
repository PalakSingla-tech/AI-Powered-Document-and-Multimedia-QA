# Explicitly mark Java and TypeScript files for GitHub Linguist
*.java linguist-detectable=true
*.ts linguist-detectable=true
*.tsx linguist-detectable=true

# Mark documentation and configuration files to be excluded from language statistics
*.md linguist-documentation=true
*.json linguist-documentation=true
*.yaml linguist-documentation=true
*.xml linguist-documentation=true
pnpm-lock.yaml linguist-generated=true
package-lock.json linguist-generated=true

# Ensure the backend source code is prioritized
backend/src/main/java/** linguist-detectable=true
